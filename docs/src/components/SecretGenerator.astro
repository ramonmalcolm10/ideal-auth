---
---

<div class="secret-generator">
  <div class="generator-row">
    <label>IDEAL_AUTH_SECRET</label>
    <div class="output-row">
      <code id="secret-output" class="output">Click "Generate" to create and copy</code>
      <button id="generate-secret" class="btn" type="button">Generate</button>
    </div>
  </div>

  <div class="generator-row">
    <label>Encryption Key</label>
    <div class="output-row">
      <code id="key-output" class="output">Click "Generate" to create and copy</code>
      <button id="generate-key" class="btn" type="button">Generate</button>
    </div>
  </div>
</div>

<style>
  .secret-generator {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 1rem 0;
  }

  .generator-row {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .generator-row label {
    font-weight: 600;
    font-size: 0.875rem;
  }

  .output-row {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .output {
    flex: 1;
    padding: 0.5rem 0.75rem;
    border-radius: 0.375rem;
    font-size: 0.8125rem;
    overflow-x: auto;
    white-space: nowrap;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-gray-7);
  }

  .output.has-value {
    font-family: var(--sl-font-mono);
    user-select: all;
  }

  .btn {
    padding: 0.5rem 0.75rem;
    border-radius: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    white-space: nowrap;
    transition: background 0.15s;
  }

  .btn:hover {
    background: var(--sl-color-gray-5);
  }

  .btn.copied {
    background: var(--sl-color-green);
    border-color: var(--sl-color-green);
  }
</style>

<script>
  function toBase64Url(bytes: Uint8Array): string {
    const binString = Array.from(bytes, (b) => String.fromCharCode(b)).join('');
    return btoa(binString).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
  }

  function toHex(bytes: Uint8Array): string {
    return Array.from(bytes, (b) => b.toString(16).padStart(2, '0')).join('');
  }

  function generateSecret(): string {
    const bytes = new Uint8Array(32);
    crypto.getRandomValues(bytes);
    return toBase64Url(bytes);
  }

  function generateEncryptionKey(): string {
    const bytes = new Uint8Array(16);
    crypto.getRandomValues(bytes);
    return toHex(bytes);
  }

  async function generateAndCopy(
    generate: () => string,
    envVar: string,
    output: HTMLElement,
    button: HTMLButtonElement,
  ) {
    const value = generate();
    const text = `${envVar}=${value}`;
    output.textContent = text;
    output.classList.add('has-value');

    await navigator.clipboard.writeText(text);
    const original = button.textContent;
    button.textContent = 'Copied!';
    button.classList.add('copied');
    setTimeout(() => {
      button.textContent = original;
      button.classList.remove('copied');
    }, 2000);
  }

  document.getElementById('generate-secret')!.addEventListener('click', (e) => {
    generateAndCopy(
      generateSecret,
      'IDEAL_AUTH_SECRET',
      document.getElementById('secret-output')!,
      e.currentTarget as HTMLButtonElement,
    );
  });

  document.getElementById('generate-key')!.addEventListener('click', (e) => {
    generateAndCopy(
      generateEncryptionKey,
      'ENCRYPTION_KEY',
      document.getElementById('key-output')!,
      e.currentTarget as HTMLButtonElement,
    );
  });
</script>
